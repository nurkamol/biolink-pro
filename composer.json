{
    "name": "nurkamol/biolink-pro",
    "description": "Self-hosted bio link / link-in-bio builder for WordPress. Drag-and-drop blocks, themes, analytics, QR codes, monetization.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/nurkamol/biolink-pro",
    "authors": [
        {
            "name": "Nurkamol Vakhidov",
            "email": "nurkamol@gmail.com",
            "homepage": "https://github.com/nurkamol",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nurkamol/biolink-pro/issues",
        "source": "https://github.com/nurkamol/biolink-pro"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "BioLinkPro\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BioLinkPro\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
